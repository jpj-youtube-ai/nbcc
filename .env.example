# Single source of truth for the app's config surface.
# The SAME keys exist as SSM parameters in AWS; ECS injects them as env vars,
# so the app reads process.env identically in both environments.
# Copy to .env for local dev (.env is gitignored). Never commit real secrets.

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Local Postgres (docker-compose). In AWS this points at RDS, value from SSM.
DATABASE_URL=postgres://app:app@localhost:5432/charity

# External APIs - sandbox/mock values locally, real keys via SSM in staging/prod.
EXTERNAL_API_ONE_BASE_URL=https://sandbox.api-one.example
EXTERNAL_API_ONE_KEY=local-dummy-key
EXTERNAL_API_TWO_KEY=local-dummy-key

# Stripe checkout (REQ-028/REQ-029). Use a Stripe TEST secret key locally; the
# real key lives only in SSM (SecureString) in staging/prod. The success/cancel
# URLs are where Stripe redirects after checkout. The price IDs are the recurring
# monthly prices from your Stripe dashboard, one per donate tier (REQ-022).
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_SUCCESS_URL=http://localhost:3000/donate/thank-you
STRIPE_CANCEL_URL=http://localhost:3000/donate
STRIPE_PRICE_BRONZE=price_dummy_bronze
STRIPE_PRICE_SILVER=price_dummy_silver
STRIPE_PRICE_GOLD=price_dummy_gold
STRIPE_PRICE_PLATINUM=price_dummy_platinum
# Stripe webhook signing secret (REQ-036/TASK-046). Verifies inbound webhook
# signatures. Use a Stripe TEST `whsec_...` locally; the real secret lives only in
# SSM (SecureString) in staging/prod. Any non-empty placeholder keeps local/CI
# signature checks working (the BDD signs its events with this same value).
STRIPE_WEBHOOK_SECRET=whsec_dummy
# Optional: a Stripe Product id (prod_...) to group one-off donations under.
# Leave blank to name an inline product instead.
STRIPE_DONATION_PRODUCT=

# Contact form forwarding (REQ-030): the form-service endpoint /api/contact POSTs
# enquiries to (e.g. a Formspree form URL https://formspree.io/f/xxxx, or an NBCC
# inbox endpoint). The real URL lives only in SSM (SecureString) in staging/prod.
# A `.example` placeholder keeps the local/CI forward STUBBED (no network).
CONTACT_FORWARD_URL=https://forward.example/contact

# Transactional email send endpoint (TASK-070): the provider URL the email client
# POSTs a single donation-confirmation message to after a successful payment. The
# real URL lives only in SSM (SecureString) in staging/prod. A `.example`
# placeholder keeps the local/CI send STUBBED (no network).
EMAIL_SEND_URL=https://email.example/send

# Base URL for the Gift Aid declaration form (TASK-075): the in-person confirmation
# email builds a unique token-addressed declaration link + a QR short link on this
# base. Not a secret (it ships in the email/QR); set the real public site URL in SSM
# for staging/prod.
DECLARATION_FORM_BASE_URL=http://localhost:3000

# Admin notification recipient (TASK-092): the NBCC inbox emailed when a monthly
# subscription lapses (Smart Retries exhausted). Not a secret; set the real inbox in
# SSM for staging/prod.
ADMIN_NOTIFICATION_EMAIL=admin@example.org

# Public site base for the self-serve donor portal magic link (TASK-100). Not a
# secret (it ships in the access email); set the real public site URL in SSM for
# staging/prod.
PORTAL_BASE_URL=http://localhost:3000

# Admin session token signing key (TASK-105). Signs the admin login session token
# (HMAC). A secret: use any non-empty placeholder locally/CI; the real long random
# key lives only in SSM (SecureString) in staging/prod. Never commit a real key.
ADMIN_SESSION_SECRET=dev-admin-session-secret

# From/Reply-To for the admin newsletter (TASK-161): the address every newsletter
# email is sent from and replies go to (a real inbox, not noreply). Not a secret
# (it ships in the email headers). Defaults to the production address.
NEWSLETTER_FROM_EMAIL=newsletter@nbcc.scot
